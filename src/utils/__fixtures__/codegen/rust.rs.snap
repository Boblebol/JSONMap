use serde::{Serialize, Deserialize};

#[derive(Debug, Serialize, Deserialize)]
pub struct Root {
    pub name: String,

    pub version: String,

    pub features: Vec<Feature>,

    pub settings: Settings,
}

#[derive(Debug, Serialize, Deserialize)]
pub struct Feature {
    pub id: String,

    pub enabled: bool,
}

#[derive(Debug, Serialize, Deserialize)]
#[serde(rename_all = "camelCase")]
pub struct Settings {
    pub theme: String,

    pub max_nodes: i64,
}
